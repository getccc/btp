# Database
DB_USER=signal
DB_PASSWORD=signal_pass
DATABASE_URL=postgresql+asyncpg://signal:signal_pass@postgres:5432/signal_platform

# Redis
REDIS_URL=redis://redis:6379/0

# DeepSeek LLM
DEEPSEEK_API_KEY=sk-xxx

# Telegram User Client (Telethon - for group monitoring)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_PHONE=+8613800138000

# Telegram Bot (for notifications)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_OWNER_CHAT_ID=987654321

# X/Twitter account pool (JSON array)
X_ACCOUNTS=[{"username":"acc1","password":"pass1","email":"acc1@example.com"},{"username":"acc2","password":"pass2","email":"acc2@example.com"}]

# BSC API Key pool (JSON array)
BSC_API_KEYS=[{"provider":"bscscan","key":"YOUR_BSCSCAN_KEY_1"},{"provider":"bscscan","key":"YOUR_BSCSCAN_KEY_2"},{"provider":"nodereal","key":"YOUR_NODEREAL_KEY"},{"provider":"moralis","key":"YOUR_MORALIS_KEY"}]

# Solana API Key pool (JSON array)
SOLANA_API_KEYS=[{"provider":"helius","key":"YOUR_HELIUS_KEY_1"},{"provider":"helius","key":"YOUR_HELIUS_KEY_2"},{"provider":"alchemy","key":"YOUR_ALCHEMY_KEY"}]

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
